   1:				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
   2:				; $Id: Z80MON083.ASM $   10/11/2025     V8.3 
   3:				; Z80 Monitor 9600 baud version With Assembler & Disassembler
   4:				; V8.0 - Added support for hardwired LED (PORTC-0) & Speaker(PORTC-1)
   5:				; V8.1 - Changed FLASHLED
   6:				; V8.2 - Improved SENDBYTE & GETBYTE 
   7:				; V8.3 - corrected SENDBYTE 
   8:				; V8.3mgh - adjusted for MGH80 hardware
   9:				; Command Line to Compile: 
  10:				; zmac.exe -c -n --oo hex,cim,lst Z80MON08.ASM
  11:				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
  12:				
  13:				;********************* HARDWARE IO ADR ************************************
  14:				; PIO 82C55 I/O
  15:     -	0000          	PIO1A:       .EQU    0              ; (INPUT)  IN 1-8
  16:     -	0001          	PIO1B:       .EQU    1              ; (INPUT) 
  17:     -	0002          	PIO1C:       .EQU    2              ; (OUTPUT)  
  18:     -	0003          	PIO1CONT:    .EQU    3              ; CONTROL BYTE PIO 82C55
  19:				
  20:     -	0005          	BDOS:	       .EQU	   0005H	        ;BDOS ENTRY POINT for EMULATOR ONLY
  21:				;********************* CONSTANTS ****************************************
  22:     -	FFFF          	RAMTOP:      .EQU    $FFFF          ; 32Kb RAM   8000H-FFFFH
  23:     -	90A8          	TEMPSTACK    .EQU    $90A8          ; Top of BASIC line input buffer so is "free ram" when BASIC resets
  24:     -	00FF          	END:         .EQU    $FF            ; Mark END OF TEXT
  25:				
  26:     -	8080          	CT_BLINK:    .EQU    $8080          ; Blink Delay
  27:     -	8081          	TX_BYTE:     .EQU    $8081          ; Byte to send
  28:     -	8082          	RX_BYTE:     .EQU    $8082          ; Byte recieved
  29:     -	8083          	FLAGS_A:     .EQU    $8083          ; Flags A: Bit 0=ECHO                            
  30:     -	8085          	COUNT_A:     .EQU    $8085          ; Counter A
  31:     -	8086          	COUNT_B:     .EQU    $8086          ; Counter B
  32:     -	8087          	COUNT_C:     .EQU    $8087          ; Counter C
  33:     -	8088          	ADDR_LO:     .EQU    $8088
  34:     -	8089          	ADDR_HI:     .EQU    $8089
  35:     -	8091          	TEMP_01:     .EQU    $8091          ; Temp Storage 1
  36:     -	8092          	TEMP_02:     .EQU    $8092          ; Temp Storage 2
  37:     -	8093          	TEMP_03:     .EQU    $8093          ; Temp Storage 3
  38:     -	8094          	TEMP_04:     .EQU    $8094          ; Temp Storage 4
  39:     -	8095          	REC_LEN:     .EQU    $8095          ; iHex Record Length 
  40:     -	8096          	REC_TYPE:    .EQU    $8096          ; iHex Record Type
  41:     -	8097          	REC_CSUM:    .EQU    $8097          ; iHex Record Checksum
  42:     -	8098          	ASM_ADDR:    .EQU    $8098          ; Assembler Destination address
  43:				
  44:     -	80A0          	ASM_BUF:     .EQU    $80A0          ; 16 byte ASM Input Buffer
  45:     -	80AB          	OUT_BUF:     .EQU    $80AB          ; 4 byte test buffer(last part of ASM_BUF)  
  46:     -	80B0          	INS_BUF:     .EQU    $80B0          ; 4 Byte Instruction Buffer
  47:     -	80B4          	PARM_BUF:    .EQU    $80B4          ; 7 Byte Parm Buffer
  48:     -	80BB          	VAL_BUF:     .EQU    $80BB          ; 5 Byte Value Buffer
  49:     -	80BB          	VAL_BUF_HI:  .EQU    $80BB          ; 2 Hi Bytes in Value Buffer
  50:     -	80BD          	VAL_BUF_LO:  .EQU    $80BD          ; 2 Lo Bytes in Value Buffer
  51:     -	80C0          	SRC_ADDR:    .EQU    $80C0          ; 2 byte source pointer storage
  52:     -	80C2          	DES_ADDR:    .EQU    $80C2          ; 2 byte destination pointer storage
  53:     -	80C4          	BLK_ADDR:    .EQU    $80C4          ; 2 byte table block pointer storage
  54:     -	80C6          	ROW_ADDR:    .EQU    $80C6          ; 2 byte table row pointer storage
  55:     -	80C8          	BLK_NUM:     .EQU    $80C8          ; 1 byte Block Number
  56:     -	80C9          	BLK_SIZE:    .EQU    $80C9          ; 1 byte Block Size
  57:     -	80CA          	ROW_NUM      .EQU    $80CA          ; 1 byte Row Number  
  58:     -	80CB          	ML_BUF:      .EQU    $80CB          ; 3 byte ML buffer
  59:     -	80CD          	ML_BTCOUNT:  .EQU    $80CD          ; Last byte of ML buffer(byte count)
  60:     -	80CE          	VAL_LO:      .EQU    $80CE          ; Converted value LO
  61:     -	80CF          	VAL_HI:      .EQU    $80CF          ; Converted value Hi
  62:				
  63:				;*******************************************************************
  64:				;*        START AFTER RESET,                                       *
  65:				;*        Function....: ready system and restart                   *
  66:				;*******************************************************************
  67:     -	0000          	             .ORG    $0000
  68:    0+4	0000  00      	             NOP                   ;A Few NOPs to let things settle down
  69:    4+4	0001  00      	             NOP
  70:    8+4	0002  00      	             NOP
  71:   12+4	0003  F3      	             DI                    ; Disable interrupt
  72:   16+10	0004  31FFFF  	             LD     SP,RAMTOP      ; Set stack pointer to top off ram
  73:   26+10	0007  C37100  	             JP     MAIN_START     ; jump to Start of program
  74:				             
  75:     -	000A  FFFFFF  	             .BYTE  $FF,$FF,$FF    ; 3 unprogramed bytes
  76:				
  77:     -	000D  204D4748	             .byte " MGH80 "  ; text string in rom
	              383020
  78:     -	0014  20562038	             .byte " V 8.3mgh "
	              2E336D67
	              6820
  79:     -	001E  2030312F	             .byte " 01/2026 "
	              32303236
	              20
  80:				
  81:     -	0030          	            .ORG    $0030
