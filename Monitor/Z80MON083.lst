 145:14663+17	24D9  CDF235  	        CALL    PRS             ; Output "Memory size"
 146:14680+17	24DC  CD9D29  	        CALL    PROMPT          ; Get input with '?'
 147:14697+17	24DF  CDB12C  	        CALL    GETCHR          ; Get next character
 148:14714+4	24E2  B7      	        OR      A               ; Set flags
 149:14718+10	24E3  C2FB24  	        JP      NZ,TSTMEM       ; If number - Test if RAM there
 150:14728+10	24E6  215D91  	        LD      HL,STLOOK       ; Point to start of RAM
 151:14738+6	24E9  23      	MLOOP:  INC     HL              ; Next byte
 152:14744+4	24EA  7C      	        LD      A,H             ; Above address FFFF ?
