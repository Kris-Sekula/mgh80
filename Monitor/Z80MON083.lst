   6:				; the original ROM code (checksum A934H). PA
   7:				
   8:				; GENERAL EQUATES
   9:				
  10:     -	0003          	CTRLC   .EQU    03H             ; Control "C"
  11:     -	0007          	CTRLG   .EQU    07H             ; Control "G"
  12:     -	0008          	BKSP    .EQU    08H             ; Back space
  13:     -	000A          	LF      .EQU    0AH             ; Line feed
  14:     -	000C          	CS      .EQU    0CH             ; Clear screen
  15:     -	000D          	CR      .EQU    0DH             ; Carriage return
  16:     -	000F          	CTRLO   .EQU    0FH             ; Control "O"
  17:     -	0011          	CTRLQ	  .EQU	  11H		          ; Control "Q"
  18:     -	0012          	CTRLR   .EQU    12H             ; Control "R"
  19:     -	0013          	CTRLS   .EQU    13H             ; Control "S"
  20:     -	0015          	CTRLU   .EQU    15H             ; Control "U"
  21:     -	001B          	ESC     .EQU    1BH             ; Escape
  22:     -	007F          	DEL     .EQU    7FH             ; Delete
  23:				
  24:				; BASIC WORK SPACE LOCATIONS
  25:				
  26:     -	9000          	WRKSPC  .EQU    09000H              ; BASIC Work space 9000-FFFF
  27:     -	9003          	USR     .EQU    WRKSPC+3H           ; "USR (x)" jump
  28:     -	9006          	OUTSUB  .EQU    WRKSPC+6H           ; "OUT p,n"
  29:     -	9007          	OTPORT  .EQU    WRKSPC+7H           ; Port (p)
  30:     -	9009          	DIVSUP  .EQU    WRKSPC+9H           ; Division support routine
  31:     -	900A          	DIV1    .EQU    WRKSPC+0AH           ; <- Values
  32:     -	900E          	DIV2    .EQU    WRKSPC+0EH           ; <-   to
  33:     -	9012          	DIV3    .EQU    WRKSPC+12H           ; <-   be
  34:     -	9015          	DIV4    .EQU    WRKSPC+15H           ; <-inserted
  35:     -	9017          	SEED    .EQU    WRKSPC+17H           ; Random number seed
  36:     -	903A          	LSTRND  .EQU    WRKSPC+3AH           ; Last random number
  37:     -	903E          	INPSUB  .EQU    WRKSPC+3EH           ; #INP (x)" Routine
  38:     -	903F          	INPORT  .EQU    WRKSPC+3FH           ; PORT (x)
  39:     -	9041          	NULLS   .EQU    WRKSPC+41H           ; Number of nulls
  40:     -	9042          	LWIDTH  .EQU    WRKSPC+42H           ; Terminal width
  41:     -	9043          	COMMAN  .EQU    WRKSPC+43H           ; Width for commas
  42:     -	9044          	NULFLG  .EQU    WRKSPC+44H           ; Null after input byte flag
  43:     -	9045          	CTLOFG  .EQU    WRKSPC+45H           ; Control "O" flag
  44:     -	9046          	LINESC  .EQU    WRKSPC+46H           ; Lines counter
  45:     -	9048          	LINESN  .EQU    WRKSPC+48H           ; Lines number
  46:     -	904A          	CHKSUM  .EQU    WRKSPC+4AH           ; Array load/save check sum
  47:     -	904C          	NMIFLG  .EQU    WRKSPC+4CH           ; Flag for NMI break routine
  48:     -	904D          	BRKFLG  .EQU    WRKSPC+4DH           ; Break flag
  49:     -	904E          	RINPUT  .EQU    WRKSPC+4EH           ; Input reflection
  50:     -	9051          	POINT   .EQU    WRKSPC+51H           ; "POINT" reflection (unused)
  51:     -	9054          	PSET    .EQU    WRKSPC+54H           ; "SET"   reflection
  52:     -	9057          	RESET   .EQU    WRKSPC+57H           ; "RESET" reflection
  53:     -	905A          	STRSPC  .EQU    WRKSPC+5AH           ; Bottom of string space
  54:     -	905C          	LINEAT  .EQU    WRKSPC+5CH           ; Current line number
  55:     -	905E          	BASTXT  .EQU    WRKSPC+5EH           ; Pointer to start of program
  56:     -	9061          	BUFFER  .EQU    WRKSPC+61H           ; Input buffer
  57:     -	9066          	STACK   .EQU    WRKSPC+66H           ; Initial stack
  58:     -	90AB          	CURPOS  .EQU    WRKSPC+0ABH          ; Character position on line
  59:     -	90AC          	LCRFLG  .EQU    WRKSPC+0ACH          ; Locate/Create flag
  60:     -	90AD          	TYPE    .EQU    WRKSPC+0ADH          ; Data type flag
  61:     -	90AE          	DATFLG  .EQU    WRKSPC+0AEH          ; Literal statement flag
  62:     -	90AF          	LSTRAM  .EQU    WRKSPC+0AFH          ; Last available RAM
  63:     -	90B1          	TMSTPT  .EQU    WRKSPC+0B1H          ; Temporary string pointer
  64:     -	90B3          	TMSTPL  .EQU    WRKSPC+0B3H          ; Temporary string pool
  65:     -	90BF          	TMPSTR  .EQU    WRKSPC+0BFH          ; Temporary string
  66:     -	90C3          	STRBOT  .EQU    WRKSPC+0C3H          ; Bottom of string space
  67:     -	90C5          	CUROPR  .EQU    WRKSPC+0C5H          ; Current operator in EVAL
  68:     -	90C7          	LOOPST  .EQU    WRKSPC+0C7H          ; First statement of loop
  69:     -	90C9          	DATLIN  .EQU    WRKSPC+0C9H          ; Line of current DATA item
  70:     -	90CB          	FORFLG  .EQU    WRKSPC+0CBH          ; "FOR" loop flag
  71:     -	90CC          	LSTBIN  .EQU    WRKSPC+0CCH          ; Last byte entered
  72:     -	90CD          	READFG  .EQU    WRKSPC+0CDH          ; Read/Input flag
  73:     -	90CE          	BRKLIN  .EQU    WRKSPC+0CEH          ; Line of break
  74:     -	90D0          	NXTOPR  .EQU    WRKSPC+0D0H          ; Next operator in EVAL
  75:     -	90D2          	ERRLIN  .EQU    WRKSPC+0D2H          ; Line of error
  76:     -	90D4          	CONTAD  .EQU    WRKSPC+0D4H          ; Where to CONTinue
  77:     -	90D6          	PROGND  .EQU    WRKSPC+0D6H          ; End of program
  78:     -	90D8          	VAREND  .EQU    WRKSPC+0D8H          ; End of variables
  79:     -	90DA          	ARREND  .EQU    WRKSPC+0DAH          ; End of arrays
  80:     -	90DC          	NXTDAT  .EQU    WRKSPC+0DCH          ; Next data item
  81:     -	90DE          	FNRGNM  .EQU    WRKSPC+0DEH          ; Name of FN argument
  82:     -	90E0          	FNARG   .EQU    WRKSPC+0E0H          ; FN argument value
  83:     -	90E4          	FPREG   .EQU    WRKSPC+0E4H          ; Floating point register
  84:     -	90E7          	FPEXP   .EQU    FPREG+3         ; Floating point exponent
  85:     -	90E8          	SGNRES  .EQU    WRKSPC+0E8H     ; Sign of result
  86:     -	90E9          	PBUFF   .EQU    WRKSPC+0E9H     ; Number print buffer
  87:     -	90F6          	MULVAL  .EQU    WRKSPC+0F6H     ; Multiplier
  88:     -	90F9          	PROGST  .EQU    WRKSPC+0F9H     ; Start of program text area
  89:     -	915D          	STLOOK  .EQU    WRKSPC+15DH     ; Start of memory test
  90:				
  91:				; BASIC ERROR CODE VALUES
  92:				
  93:     -	0000          	NF      .EQU    00H             ; NEXT without FOR
  94:     -	0002          	SN      .EQU    02H             ; Syntax error
  95:     -	0004          	RG      .EQU    04H             ; RETURN without GOSUB
  96:     -	0006          	OD      .EQU    06H             ; Out of DATA
  97:     -	0008          	FC      .EQU    08H             ; Function call error
  98:     -	000A          	OV      .EQU    0AH             ; Overflow
  99:     -	000C          	OM      .EQU    0CH             ; Out of memory
 100:     -	000E          	UL      .EQU    0EH             ; Undefined line number
 101:     -	0010          	BS      .EQU    10H             ; Bad subscript
 102:     -	0012          	DD      .EQU    12H             ; Re-DIMensioned array
 103:     -	0014          	DZ      .EQU    14H             ; Division by zero (/0)
 104:     -	0016          	ID      .EQU    16H             ; Illegal direct
 105:     -	0018          	TM      .EQU    18H             ; Type miss-match
 106:     -	001A          	OS      .EQU    1AH             ; Out of string space
 107:     -	001C          	LS      .EQU    1CH             ; String too long
 108:     -	001E          	ST      .EQU    1EH             ; String formula too complex
 109:     -	0020          	CN      .EQU    20H             ; Can't CONTinue
 110:     -	0022          	UF      .EQU    22H             ; UnDEFined FN function
 111:     -	0024          	MO      .EQU    24H             ; Missing operand
 112:     -	0026          	HX      .EQU    26H             ; HEX error
 113:     -	0028          	BN      .EQU    28H             ; BIN error
