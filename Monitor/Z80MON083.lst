1787:12702+10	0DB4  C3C90D  	             JP    AFP_EXIT
1788:				             
1789:12712+19	0DB7  DD7E00  	AFP_MATCH:   LD    A,(IX+0)        ;Get Table ML Byte 1
1790:12731+13	0DBA  32CB80  	             LD    (ML_BUF),A      ;Save it in M_BUF[0]
1791:12744+19	0DBD  DD7E01  	             LD    A,(IX+1)        ;Get Table ML Byte 2
1792:12763+13	0DC0  32CC80  	             LD    (ML_BUF+1),A    ;Save it in M_BUF[1]
1793:12776+19	0DC3  DD7E02  	             LD    A,(IX+2)        ;Get Table  ML Byte count
1794:12795+13	0DC6  32CD80  	             LD    (ML_BUF+2),A    ;Save it in M_BUF[2]
1795:				             
1796:12808+10	0DC9  E1      	AFP_EXIT:    POP   HL
1797:12818+10	0DCA  C1      	             POP   BC
1798:12828+10	0DCB  D1      	             POP   DE
1799:12838+10	0DCC  C9      	             RET
