 576:				;******************************************************************
 577:				;        GETBYTE                                    WORKS 12/06/24;
 578:				;        Wait for 1 serial byte  
 579:				;        Output.......: RX_BYTE                                   
 580:				;        1200 baud delay=833.3us   2400 baud=416.6us  9600= 104.16us
 581:				;******************************************************************
 582: 3759+11	061B  C5      	GETBYTE:     PUSH   BC 
 583: 3770+7	061C  0E09    	             LD     C,09           ;Set Bit Count
 584: 3777+11	061E  DB02    	STARTWAIT:   IN     A,(PIO1C)      ;READ PORTC       
 585: 3788+8	0620  CB67    	             BIT    4,A            ;Test BIT 0
 586: 3796+10	0622  C21E06  	             JP     NZ,STARTWAIT   ;If HI keep checking
 587:				             
 588: 3806+7	0625  0612    	             LD     B,18           ;9600 baud = 18 (1/2 Bit)           
 589: 3813+8+5	0627  10FE    	NEXT_IN_BIT: DJNZ   NEXT_IN_BIT    ;Delay 1/2 or 1 bit
 590:				             
 591: 3821+11	0629  DB02    	             IN     A,(PIO1C)      ; READ PORTC       
 592: 3832+4	062B  17      	             RLA                   ;Rotate BIT4 into CARRY
 593: 3836+4	062C  17      	             RLA
 594: 3840+4	062D  17      	             RLA
 595: 3844+4	062E  17      	             RLA
 596: 3848+13	062F  3A8280  	             LD     A,(RX_BYTE)    ;Get RX_BYTE
 597: 3861+4	0632  1F      	             RRA                   ;Rotate CARRY to BIT7
 598: 3865+13	0633  328280  	             LD     (RX_BYTE),A    ;Save result
 599: 3878+7	0636  061A    	             LD     B,26           ;9600 Full bit=32 (-20us for code)=26          
 600: 3885+4	0638  0D      	             DEC    C              ;Decrement Bit Count
 601: 3889+10	0639  C22706  	             JP     NZ,NEXT_IN_BIT ; If not done NEXT_IN_BIT
 602:				                                   ;code between "READ PORTC" and this point
 603:				                                   ;takes about 20us to execute 
 604: 3899+13	063C  3A8280  	             LD     A,(RX_BYTE)    ;Get RX_BYTE
 605: 3912+10	063F  C1      	             POP    BC 
 606: 3922+10	0640  C9      	             RET
