 537:				;******************************************************************
 538:				;        SENDBYTE                             working! 10/11/25
 539:				;        Send 1 serial byte  
 540:				;        Input.......: A                                 
 541:				;        1200 baud delay=833.3us  2400 baud=416.6us 9600= 104.16us
 542:				;******************************************************************
 543: 3458+11	05DC  F5      	SENDBYTE:    PUSH   AF     
 544: 3469+11	05DD  C5      	             PUSH   BC 
 545: 3480+13	05DE  328180  	             LD     (TX_BYTE),A   ;Save Byte to output
 546: 3493+7	05E1  0E08    	             LD     C,08          ;Set Bit Count
 547: 3500+11	05E3  DB02    	             IN     A,(PIO1C)       
 548: 3511+8	05E5  CB9F    	             RES    3,A
 549: 3519+11	05E7  D302    	             OUT    (PIO1C),A     ;Output LOW (Start Bit)
 550: 3530+7	05E9  0619    	SEND_BIT:    LD     B,25          ;9600 baud = 25
 551: 3537+8+5	05EB  10FE    	DEL_BIT1:    DJNZ   DEL_BIT1      ;Delay 1 bit (decrement B till zero)
 552: 3545+13	05ED  3A8180  	             LD     A,(TX_BYTE)   ;Get Byte to send
 553: 3558+4	05F0  1F      	             RRA                  ;Shift Right through Carry 
 554: 3562+13	05F1  328180  	             LD     (TX_BYTE),A   ;Save shifted result
 555: 3575+10	05F4  DA0006  	             JP     C,OUT_HI      ;If Carry Set goto OUT_HI
 556: 3585+11	05F7  DB02    	             IN     A,(PIO1C)       
 557: 3596+8	05F9  CB9F    	             RES    3,A
 558: 3604+11	05FB  D302    	             OUT    (PIO1C),A      ;Output LOW
 559: 3615+10	05FD  C30606  	             JP     NEXT_BIT             
 560: 3625+11	0600  DB02    	OUT_HI:      IN     A,(PIO1C)       
 561: 3636+8	0602  CBDF    	             SET    3,A
 562: 3644+11	0604  D302    	             OUT    (PIO1C),A      ;Output HI
 563: 3655+4	0606  0D      	NEXT_BIT:    DEC    C
 564: 3659+10	0607  C2E905  	             JP     NZ,SEND_BIT
 565: 3669+7	060A  0619    	             LD     B,25          ;9600 baud = 25                  
 566: 3676+8+5	060C  10FE    	DEL_BIT2:    DJNZ   DEL_BIT2      ;Delay 1 bit(last data bit)
 567: 3684+11	060E  DB02    	             IN     A,(PIO1C)       
 568: 3695+8	0610  CBDF    	             SET    3,A
 569: 3703+11	0612  D302    	             OUT    (PIO1C),A      ;Output HI
 570: 3714+7	0614  0632    	             LD     B,50          ;9600 baud (2 bits) = 50                  
 571: 3721+8+5	0616  10FE    	DEL_BIT3:    DJNZ   DEL_BIT3      ;Delay 2 bits (parity & stop)
 572: 3729+10	0618  C1      	             POP    BC
 573: 3739+10	0619  F1      	             POP    AF
 574: 3749+10	061A  C9      	             RET
