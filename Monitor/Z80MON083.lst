 726: 4465+7	06A5  FE61    	TOUPPER:     CP     'a'        ;is it <'a'?
 727: 4472+10	06A7  FAB106  	             JP     M,TOUP_EXIT ;Exit
 728: 4482+7	06AA  FE7B    	             CP     07Bh        ;is it >'z'?
 729: 4489+10	06AC  F2B106  	             JP     P,TOUP_EXIT ;Exit 
 730: 4499+7	06AF  E65F    	             AND    05Fh        ;Mask Bits
