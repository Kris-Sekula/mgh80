 509:				;******************************************************************
 510: 3220+13	05A7  328780  	BEEP:        LD     (COUNT_C),A     ;Save A (frequency)
 511: 3233+4	05AA  78      	             LD     A,B
 512: 3237+13	05AB  328680  	             LD     (COUNT_B),A     ;Save C (duration)
 513: 3250+7	05AE  1664    	BEEP_LOOP1:  LD     D, 100         ; D = cycle count multiplier (100)
 514: 3257+11	05B0  DB02    	BEEP_LOOP2:  IN     A,(PIO1C)      ;READ PORTC  
 515: 3268+7	05B2  F602    	             ORA    2
 516: 3275+11	05B4  D302    	             OUT    (PIO1C),A   ; Output to PORTC (SPEAKER HIGH)
 517: 3286+7	05B6  0600    	             LD     B, 0
 518: 3293+13	05B8  3A8780  	             LD     A, (COUNT_C)  ; 
 519: 3306+4	05BB  4F      	             LD     C, A          ; 
 520: 3310+17	05BC  CD6505  	             CALL   PAUSE         ; Delay BC * 100us
 521:				             
 522: 3327+11	05BF  DB02    	             IN     A,(PIO1C)   ;READ PORTC
 523: 3338+7	05C1  E6FD    	             AND    0FDh
 524: 3345+11	05C3  D302    	             OUT    (PIO1C),A   ; Output to PORTC (SPEAKER LOW)
 525: 3356+13	05C5  3A8780  	             LD     A, (COUNT_C)
 526: 3369+4	05C8  4F      	             LD     C, A
 527: 3373+17	05C9  CD6505  	             CALL   PAUSE       ; Delay BC * 100us
 528: 3390+4	05CC  15      	             DEC    D
 529: 3394+4	05CD  7A      	             LD     A,D
 530: 3398+10	05CE  C2B005  	             JP     NZ,BEEP_LOOP2   ;Loop if not done             
 531: 3408+13	05D1  3A8680  	             LD     A,(COUNT_B)    ;Get Loop Count
 532: 3421+4	05D4  3D      	             DEC    A
 533: 3425+13	05D5  328680  	             LD     (COUNT_B),A     ;Save New value
 534: 3438+10	05D8  C2AE05  	             JP     NZ,BEEP_LOOP1   ;Loop if not done
 535: 3448+10	05DB  C9      	             RET      
