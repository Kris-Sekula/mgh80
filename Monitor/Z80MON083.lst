 733:				;******************************************************************
 734:				; HEXASCII_VAL
 735:				; Convert The ASCII character in A to it's HEX value in A
 736:				; RETURN 0xFF if not a hex value
 737:				;******************************************************************
 738: 4516+17	06B2  CDA506  	HEXASCII_VAL:CALL   TOUPPER
 739: 4533+7	06B5  FE47    	             CP     'G'         ;is it >'F'?
 740: 4540+10	06B7  F2CF06  	             JP     P,ERR_RET   ; ERRROR
 741: 4550+7	06BA  FE30    	             CP     '0'         ;is it <'0'?
 742: 4557+10	06BC  FACF06  	             JP     M,ERR_RET   ; ERRROR
 743: 4567+7	06BF  FE3A    	             CP     03Ah        ;is it <='9'?
 744: 4574+10	06C1  FACC06  	             JP     M,MASK_RET  ; Convert & return
 745: 4584+7	06C4  FE41    	             CP     'A'         ;is it < 'A'?
 746: 4591+10	06C6  FACF06  	             JP     M,ERR_RET   ; ERRROR
 747: 4601+7	06C9  D637    	             SUB    037h        ;must be 'A'-'F' - Convert to Value  
 748: 4608+10	06CB  C9      	             RET                ;Return
 749: 4618+7	06CC  E60F    	MASK_RET:    AND    0Fh
 750: 4625+10	06CE  C9      	             RET             
 751: 4635+7	06CF  3EFF    	ERR_RET:     LD     A,0FFh      ; ERROR return Val
 752: 4642+10	06D1  C9      	             RET       
