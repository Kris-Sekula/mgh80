 433:				;******************************************************************
 434:				;        INIT_PIO  8255                                               
 435:				;  BIT 0 = PORTC(Lower) 1=INPUT 0=OUTPUT      
 436:				;  BIT 1 = PORTB  1=INPUT 0=OUTPUT
 437:				;  BIT 2 = MODE  0 or 1
 438:				;  BIT 3 = PORTC(Upper) 1=INPUT 0=OUTPUT
 439:				;  BIT 4 = PORTA  1=INPUT 0=OUTPUT
 440:				;  BIT 5&6 = 00=0, 01=1, 1?=2
 441:				;  BIT 7 = MODE SET FLAG  1=Active
 442:				;******************************************************************
 443:				;INIT_PIO:    LD     A,10000010B    ; A= OUT, B= IN C= OUT  (DATA FRA LCD)
 444:				
 445: 2871+7	0560  3E8A    	INIT_PIO:    LD     A,10001010B    ; A=OUT, B=IN C=(lower)OUT (Upper)IN
 446: 2878+11	0562  D303    	             OUT    (PIO1CONT),A
 447: 2889+10	0564  C9      	             RET
 448:				             
 449:				;******************************************************************
 450:				;        SUB-RUTINE..: PAUSE                                      ;
 451:				;        Function....: Pause in 100uS. times value in BC          ;
 452:				;        Input.......: BC reg                                     ;
 453:				;        Output......: no                                         ;
 454:				;        call........: NONE                                       ;
 455:				;        Info........: KEA.      dato: 23/5-93                    ;
 456:				;******************************************************************
 457: 2899+11	0565  F5      	PAUSE:       PUSH   AF
 458: 2910+4	0566  04      	             INC    B
 459: 2914+4	0567  0C      	             INC    C              ; ADJUST THE LOOP
 460: 2918+7	0568  3E13    	PAUSELOOP1:  LD     A,13H          ; ADJUST THE TIME 13h IS FOR 4 MHZ
 461: 2925+4	056A  3D      	PAUSELOOP2:  DEC    A              ; DEC COUNTER. 4 T-states = 1 uS.
 462: 2929+10	056B  C26A05  	             JP     NZ,PAUSELOOP2  ; JUMP TO PAUSELOOP2 IF A <> 0.
 463: 2939+4	056E  0D      	             DEC    C              ; DEC COUNTER
 464: 2943+10	056F  C26805  	             JP     NZ,PAUSELOOP1  ; JUMP TO PAUSELOOP1 IF C <> 0.
 465:				
 466: 2953+8+5	0572  10F4    	             DJNZ   PAUSELOOP1     ; JUMP TO PAUSELOOP1 IF B <> 0.
 467: 2961+10	0574  F1      	PAUSESLUT:   POP    AF
 468: 2971+10	0575  C9      	             RET
 469:				             
 470:				;******************************************************************
 471:				;        SUB-RUTINE..: DELAY4                                     ;
 472:				;        Function....: DELAY in 4uS. times value in BC            ;
 473:				;        Input.......: BC reg                                     ;
 474:				;******************************************************************
 475: 2981+4	0576  04      	DELAY4:      INC    B
 476: 2985+4	0577  0C      	             INC    C              ; Adjust Loop 
 477: 2989+4	0578  0D      	DELAY4LOOP:  DEC    C              ; DEC COUNTER. 4 T-states = 1 uS.
 478: 2993+10	0579  C27805  	             JP     NZ,DELAY4LOOP  ; JUMP TO DELAY4LOOP IF C <> 0. 
 479:				                                   ;  10 T States 2.5us 
 480: 3003+8+5	057C  10FA    	             DJNZ   DELAY4LOOP     ; JUMP TO DELAY4LOOP IF B <> 0.
 481: 3011+10	057E  C9      	             RET
 482:				
 483:				
 484:				;******************************************************************
 485:				; FLASHLED    Flash LED on PORTC BIT0  A times  BC * 100us = delay
 486:				;******************************************************************
 487: 3021+4	057F  3C      	FLASHLED:    INC    A              ; Add 1 to A (adjust loop count)
 488: 3025+13	0580  328580  	             LD     (COUNT_A),A    ;Save A -> COUNT_A
 489: 3038+10	0583  218580  	             LD     HL,COUNT_A     ;Point HL to Loop Count
 490: 3048+20	0586  ED438680	             LD     (COUNT_B),BC   ;Save BC in COUNT_B & COUNT_C
 491:				             
 492: 3068+11	058A  DB00    	FLASH_LOOP:  IN     A,(PIO1A)      ;READ PORTA  
 493: 3079+7	058C  F601    	             ORA    1
 494: 3086+11	058E  D300    	             OUT    (PIO1A),A     ; Output to PORTA (LED ON)
 495: 3097+20	0590  ED4B8680	             LD     BC,(COUNT_B)   
 496: 3117+17	0594  CD6505  	             CALL   PAUSE         ; Delay BC * 100us
 497:				             
 498: 3134+7	0597  E6FE    	             AND    0FEh        ; A should still have PORTA value
 499: 3141+11	0599  D300    	             OUT    (PIO1A),A   ; Output to PORTA (LED OFF)
 500: 3152+20	059B  ED4B8680	             LD     BC,(COUNT_B)
 501: 3172+17	059F  CD6505  	             CALL   PAUSE        ; Delay BC * 100us
 502:				             
 503: 3189+11	05A2  35      	             DEC    (HL)          ; DEC COUNT_A
 504: 3200+10	05A3  C28A05  	             JP     NZ,FLASH_LOOP   ;Loop if not done
 505: 3210+10	05A6  C9      	             RET      
