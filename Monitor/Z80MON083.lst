 654:				;******************************************************************
 655:				; ISHEXDIGIT
 656:				;  
 657:				; RETURN Z=1 if A is 'A'-'F' otherwise Z=0 (A is unchanged)
 658:				; NOTE: A MUST be a non-zero ASCII Digit  
 659:				;******************************************************************
 660: 4173+7	0667  FE41    	ISHEXDIGIT:  CP    'A'             ; is A <'A'?
 661: 4180+10	0669  FA7606  	             JP    M,ISHEXD_EXIT   ; YES=just exit Z=0 
 662: 4190+7	066C  FE47    	             CP    'G'             ; is A <='F'?
 663: 4197+10	066E  FA7406  	             JP    M,ISHEXD_ZRET   ; YES=return Z=1
 664: 4207+10	0671  C37606  	             JP    ISHEXD_EXIT     ; otherwise return Z=0
 665:				             
 666: 4217+4	0674  BF      	ISHEXD_ZRET: CP    A               ;Set Z=1  and Return               
 667: 4221+10	0675  C9      	             RET
 668:				                              
 669: 4231+7	0676  FE00    	ISHEXD_EXIT: CP    0               ;Set Z=0  and Return
 670: 4238+10	0678  C9      	             RET
