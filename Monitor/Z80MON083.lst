1763:12459+13	0D7C  3AC980  	             LD    A,(BLK_SIZE)    ;Get Block Size
1764:12472+4	0D7F  6F      	             LD    L,A             ;L=ROW COUNTER
1765:12476+10	0D80  110A00  	AFP_NEXTROW: LD    DE,000Ah        ;10 bytes per row
1766:12486+15	0D83  DD19    	             ADD   IX,DE           ;Add 10 to Address (next block)
1767:12501+20	0D85  DD22C680	             LD    (ROW_ADDR),IX   ;Save ROW Address
1768:12521+14	0D89  FD21B480	             LD    IY,PARM_BUF     ;IY=PARM_BUF              
1769:12535+7	0D8D  0E07    	             LD    C,07h           ;Loop count =7
1770:12542+19	0D8F  DD7E00  	AFP_CMPLOOP: LD    A,(IX+0)        ;Get Table byte->A
1771:12561+19	0D92  FD4600  	             LD    B,(IY+0)        ;Get PARM_BUF byte->B  
1772:12580+4	0D95  B8      	             CP    B               ;Compare A-B
1773:12584+10	0D96  C2A40D  	             JP    NZ,AFP_NOMATCH  ;Mismatch = Exit loop
1774:12594+10	0D99  DD23    	             INC   IX              ;Advance pointers
1775:12604+10	0D9B  FD23    	             INC   IY
1776:12614+4	0D9D  0D      	             DEC   C               ;Decrement loop count
1777:12618+10	0D9E  C28F0D  	             JP    NZ,AFP_CMPLOOP  ;Not done yet - continue
1778:12628+10	0DA1  C3B70D  	             JP    AFP_MATCH       ;Match Found Get ML Bytes & Counts
1779:				                                   ;Match not found, advance to next block                 
1780:12638+4	0DA4  2D      	AFP_NOMATCH: DEC   L               ;Decrement row counter 
