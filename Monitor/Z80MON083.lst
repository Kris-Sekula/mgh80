 642:				;******************************************************************
 643:				; IS_DIGIT
 644:				;  
 645:				; RETURN Z=1 if A is 'A'-'F' otherwise Z=0 (A is unchanged )
 646:				; NOTE: A MUST be a non-zero ASCII Digit 
 647:				;******************************************************************
 648: 4119+17	065D  CD8C06  	IS_DIGIT:    CALL  ISDECDIGIT     ;Is it '0'-'9' 
 649: 4136+10	0660  CA6606  	             JP    Z,IS_DIG_EXIT  ;YES=EXIT with Z=1
 650:				
