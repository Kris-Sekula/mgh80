1782:12652+20	0DA8  DD2AC680	             LD    IX,(ROW_ADDR)   ;Get Saved ROW Address->IX
1783:12672+10	0DAC  C3800D  	             JP    AFP_NEXTROW     ;Continue 
1784:				             
1785:12682+7	0DAF  3E00    	AFP_NOFIND:  LD    A,0             ;Not Found set ML_BUF[2]=0  
