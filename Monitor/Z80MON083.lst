 127:14504+6	24B5  F9      	        LD      SP,HL           ; Set up a temporary stack
 128:14510+10	24B6  C3F740  	        JP      INITST          ; Go to initialise
 129:				
 130:14520+10	24B9  117F27  	INIT:   LD      DE,INITAB       ; Initialise workspace
 131:14530+7	24BC  0663    	        LD      B,INITBE-INITAB+3; Bytes to copy
 132:14537+10	24BE  210090  	        LD      HL,WRKSPC       ; Into workspace RAM
 133:14547+7	24C1  1A      	COPY:   LD      A,(DE)          ; Get source
 134:14554+7	24C2  77      	        LD      (HL),A          ; To destination
 135:14561+6	24C3  23      	        INC     HL              ; Next destination
 136:14567+6	24C4  13      	        INC     DE              ; Next source
 137:14573+4	24C5  05      	        DEC     B               ; Count bytes
 138:14577+10	24C6  C2C124  	        JP      NZ,COPY         ; More to move
 139:14587+6	24C9  F9      	        LD      SP,HL           ; Temporary stack
