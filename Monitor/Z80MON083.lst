 672:				;******************************************************************
 673:				; ASCII2BYTE
 674:				; Convert 2 Hex ASCII bytes in HL to HEX Value in A
 675:				; NOTE: L=MSB, H=LSB since strings are usually Hi,Lo eg:"35"
 676:				; if we use LD HL,(first_char) HL will be H='5' and L='3'
 677:				; NOTE: The values in H&L are assumed to be a valid hex characters
 678:				;******************************************************************
 679: 4248+11	0679  C5      	ASCII2BYTE:  PUSH  BC              ;Save BC
 680: 4259+4	067A  7D      	             LD    A,L             ; Get High Byte from L
 681: 4263+17	067B  CDB206  	             CALL  HEXASCII_VAL    ; Convert to Value in A
 682: 4280+4	067E  37      	             SCF                   ; Set Carry 
 683: 4284+4	067F  3F      	             CCF                   ; Invert Carry Flag (Carry is now cleared) 
 684: 4288+4	0680  17      	             RLA                   ; Shift Left 4x
 685: 4292+4	0681  17      	             RLA
 686: 4296+4	0682  17      	             RLA
 687: 4300+4	0683  17      	             RLA
 688: 4304+4	0684  47      	             LD    B,A             ;Save in B
 689: 4308+4	0685  7C      	             LD    A,H             ; Get Low byte from H
 690: 4312+17	0686  CDB206  	             CALL  HEXASCII_VAL    ; Convert to a value
 691: 4329+4	0689  80      	             ADD   A,B             ; Add Hi value
 692: 4333+10	068A  C1      	             POP   BC              ; Restore BC
 693: 4343+10	068B  C9      	             RET                   ; Return
 694:				
 695:				;******************************************************************
 696:				; ISDECDIGIT
 697:				;  
 698:				; RETURN A=1 if A is '0'-'9' otherwise Z=0 (A is unchanged)
 699:				; NOTE: A MUST be a non-zero ASCII Digit 
 700:				;******************************************************************
 701: 4353+7	068C  FE30    	ISDECDIGIT:  CP    '0'             ; is A <'0'?
 702: 4360+10	068E  FA9B06  	             JP    M,ISDECD_EXIT   ; YES= exit with Z=0 
 703: 4370+7	0691  FE3A    	             CP    03Ah            ; is A <='9'?
 704: 4377+10	0693  FA9906  	             JP    M,ISDECD_ZRET   ; YES=return Z=1
 705: 4387+10	0696  C39B06  	             JP    ISDECD_EXIT     ; otherwise just exit with Z=0
 706:				             
 707: 4397+4	0699  BF      	ISDECD_ZRET: CP    A               ;Set Z=1  and Return
 708: 4401+10	069A  C9      	             RET
 709:				
 710: 4411+7	069B  FE00    	ISDECD_EXIT: CP    0               ;Set Z=0  and Return
 711: 4418+10	069D  C9      	             RET
