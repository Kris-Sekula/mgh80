8120          	Inner:
8120  1B      		DEC DE                  	;Decrements DE
8121  7A      		LD A, D                 	;Copies D into A
8122  B3      		OR E                    	;Bitwise OR of E with A (now, A = D | E)
8123  C22081  		JP NZ, Inner            	;Jumps back to Inner: label if A is not zero
